{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://music.tsonu.com/schemas/song.schema.json",
  "title": "Tsonu Published Song",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "entityType",
    "songId",
    "slug",
    "title",
    "artistName",
    "placements"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "entityType": { "const": "song" },
    "songId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
    "slug": { "$ref": "common.defs.schema.json#/$defs/slug" },
    "title": { "type": "string", "minLength": 1 },
    "artistName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "lyrics": { "type": "string" },
    "credits": {
      "type": "array",
      "items": { "$ref": "common.defs.schema.json#/$defs/credit" }
    },
    "tags": {
      "type": "array",
      "items": { "$ref": "common.defs.schema.json#/$defs/slug" },
      "uniqueItems": true
    },
    "placements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["releaseId", "releaseSlug", "releaseTitle", "releaseKind", "trackId", "trackSlug", "recordingId", "trackNumber"],
        "properties": {
          "releaseId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
          "releaseSlug": { "$ref": "common.defs.schema.json#/$defs/slug" },
          "releaseTitle": { "type": "string", "minLength": 1 },
          "releaseKind": {
            "type": "string",
            "enum": ["album", "ep", "single", "demo", "preview", "collection", "prerelease"]
          },
          "trackId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
          "trackSlug": { "$ref": "common.defs.schema.json#/$defs/slug" },
          "recordingId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
          "trackNumber": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}

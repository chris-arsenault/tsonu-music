{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://music.tsonu.com/schemas/draft-release.schema.json",
  "title": "Tsonu Draft Release",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "entityType",
    "releaseId",
    "slug",
    "title",
    "artistName",
    "releaseKind",
    "releaseStatus",
    "publishState",
    "updatedAt",
    "tracks"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "entityType": { "const": "draftRelease" },
    "releaseId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
    "slug": { "$ref": "common.defs.schema.json#/$defs/slug" },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string" },
    "artistName": { "type": "string", "minLength": 1 },
    "releaseKind": {
      "type": "string",
      "enum": ["album", "ep", "single", "demo", "preview", "collection", "prerelease"]
    },
    "releaseStatus": {
      "type": "string",
      "enum": ["official", "demo", "promo", "prerelease", "bootleg"]
    },
    "releaseDate": { "$ref": "common.defs.schema.json#/$defs/isoDate" },
    "publishState": {
      "type": "string",
      "enum": ["draft", "ready", "published", "withdrawn"]
    },
    "updatedAt": { "$ref": "common.defs.schema.json#/$defs/isoDateTime" },
    "description": { "type": "string" },
    "copyright": { "type": "string" },
    "artwork": { "$ref": "common.defs.schema.json#/$defs/artwork" },
    "credits": {
      "type": "array",
      "items": { "$ref": "common.defs.schema.json#/$defs/credit" }
    },
    "links": {
      "type": "array",
      "items": { "$ref": "common.defs.schema.json#/$defs/externalLink" }
    },
    "tags": {
      "type": "array",
      "items": { "$ref": "common.defs.schema.json#/$defs/slug" },
      "uniqueItems": true
    },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "trackId",
          "songId",
          "recordingId",
          "discNumber",
          "trackNumber",
          "slug",
          "title"
        ],
        "properties": {
          "trackId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
          "songId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
          "recordingId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
          "discNumber": { "type": "integer", "minimum": 1 },
          "trackNumber": { "type": "integer", "minimum": 1 },
          "slug": { "$ref": "common.defs.schema.json#/$defs/slug" },
          "title": { "type": "string", "minLength": 1 },
          "explicit": { "type": "boolean" },
          "isrc": { "type": "string" },
          "description": { "type": "string" },
          "credits": {
            "type": "array",
            "items": { "$ref": "common.defs.schema.json#/$defs/credit" }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://music.tsonu.com/schemas/draft-song.schema.json",
  "title": "Tsonu Draft Song",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "entityType",
    "songId",
    "slug",
    "title",
    "artistName",
    "updatedAt",
    "recordings"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "entityType": { "const": "draftSong" },
    "songId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
    "slug": { "$ref": "common.defs.schema.json#/$defs/slug" },
    "title": { "type": "string", "minLength": 1 },
    "artistName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "lyrics": { "type": "string" },
    "credits": {
      "type": "array",
      "items": { "$ref": "common.defs.schema.json#/$defs/credit" }
    },
    "artwork": { "$ref": "common.defs.schema.json#/$defs/artwork" },
    "tags": {
      "type": "array",
      "items": { "$ref": "common.defs.schema.json#/$defs/slug" },
      "uniqueItems": true
    },
    "updatedAt": { "$ref": "common.defs.schema.json#/$defs/isoDateTime" },
    "recordings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "recordingId",
          "slug",
          "title",
          "versionType",
          "explicit"
        ],
        "properties": {
          "recordingId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
          "slug": { "$ref": "common.defs.schema.json#/$defs/slug" },
          "title": { "type": "string", "minLength": 1 },
          "versionTitle": { "type": "string" },
          "versionType": {
            "type": "string",
            "enum": ["studio_master", "album_master", "single_master", "demo", "preview", "live", "alternate", "remaster"]
          },
          "artistName": { "type": "string" },
          "durationSeconds": { "type": "number", "minimum": 0 },
          "explicit": { "type": "boolean" },
          "isrc": { "type": "string" },
          "description": { "type": "string" },
          "sourceMaster": { "$ref": "common.defs.schema.json#/$defs/sourceMaster" },
          "encodeJobIds": {
            "type": "array",
            "items": { "$ref": "common.defs.schema.json#/$defs/stableId" },
            "uniqueItems": true
          }
        }
      }
    }
  }
}

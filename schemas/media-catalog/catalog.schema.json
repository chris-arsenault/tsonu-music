{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://music.tsonu.com/schemas/catalog.schema.json",
  "title": "Tsonu Published Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "entityType", "generatedAt", "artist", "releases", "songs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "entityType": { "const": "catalog" },
    "generatedAt": { "$ref": "common.defs.schema.json#/$defs/isoDateTime" },
    "artist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "slug"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": { "$ref": "common.defs.schema.json#/$defs/slug" }
      }
    },
    "releases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "releaseId",
          "slug",
          "title",
          "releaseKind",
          "releaseStatus",
          "releaseDate",
          "status",
          "visibility",
          "manifestPath",
          "artwork",
          "trackCount",
          "totalDurationSeconds"
        ],
        "properties": {
          "releaseId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
          "slug": { "$ref": "common.defs.schema.json#/$defs/slug" },
          "title": { "type": "string", "minLength": 1 },
          "subtitle": { "type": "string" },
          "releaseKind": {
            "type": "string",
            "enum": ["album", "ep", "single", "demo", "preview", "collection", "prerelease"]
          },
          "releaseStatus": {
            "type": "string",
            "enum": ["official", "demo", "promo", "prerelease", "bootleg"]
          },
          "releaseDate": { "$ref": "common.defs.schema.json#/$defs/isoDate" },
          "status": { "const": "published" },
          "visibility": {
            "type": "string",
            "enum": ["public", "unlisted"]
          },
          "manifestPath": { "$ref": "common.defs.schema.json#/$defs/relativePath" },
          "artwork": { "$ref": "common.defs.schema.json#/$defs/artwork" },
          "trackCount": { "type": "integer", "minimum": 0 },
          "totalDurationSeconds": { "type": "number", "minimum": 0 },
          "tags": {
            "type": "array",
            "items": { "$ref": "common.defs.schema.json#/$defs/slug" },
            "uniqueItems": true
          },
          "links": {
            "type": "array",
            "items": { "$ref": "common.defs.schema.json#/$defs/externalLink" }
          }
        }
      }
    },
    "songs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["songId", "slug", "title", "artistName"],
        "properties": {
          "songId": { "$ref": "common.defs.schema.json#/$defs/stableId" },
          "slug": { "$ref": "common.defs.schema.json#/$defs/slug" },
          "title": { "type": "string", "minLength": 1 },
          "artistName": { "type": "string", "minLength": 1 },
          "artwork": { "$ref": "common.defs.schema.json#/$defs/artwork" },
          "tags": {
            "type": "array",
            "items": { "$ref": "common.defs.schema.json#/$defs/slug" },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
